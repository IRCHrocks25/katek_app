# Copy this file to `.env` (same directory as manage.py) and fill in real values.
# Never commit `.env` itself.

# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# From-address used on outgoing email. The domain must be verified in Resend.
EMAIL_FROM=Katek <hello@katek.app>

# Reply-to address for outgoing email
EMAIL_REPLY_TO=support@katek.app

# Public origin used to build absolute links in emails (login, launchpad, etc.)
SITE_URL=http://localhost:8000

# Database connection string. When unset, the app falls back to a local SQLite file.
# Examples:
#   Postgres (Railway, Supabase, Neon, RDS, ...):
#     postgres://USER:PASSWORD@HOST:PORT/DBNAME
#   Local SQLite (default — same as leaving DATABASE_URL blank):
#     sqlite:///db.sqlite3
DATABASE_URL=
